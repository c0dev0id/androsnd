<?xml version="1.0" encoding="utf-8"?>
<!-- Full-screen overlay for key capture.
     Visibility toggled between GONE/VISIBLE by MainActivity. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark">

    <!-- Key Capture screen -->
    <LinearLayout
        android:id="@+id/wizard_screen_capture"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center"
        android:visibility="visible">

        <!-- Name of the preset being edited -->
        <TextView
            android:id="@+id/wizard_capture_preset_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <!-- Progress indicator: "Action 1 of 8" -->
        <TextView
            android:id="@+id/wizard_capture_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- Name of the action being mapped -->
        <TextView
            android:id="@+id/wizard_capture_action"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:textSize="28sp"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- Current key code for this action -->
        <TextView
            android:id="@+id/wizard_capture_current"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/colorPrimary"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <!-- "Press a key..." prompt -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/wizard_press_key"
            android:textColor="@color/text_secondary"
            android:textSize="18sp"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Skip button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_wizard_skip"
            style="@style/Widget.Androsnd.Button.Outlined"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/wizard_skip"
            android:layout_marginBottom="@dimen/spacing_xxl" />

        <!-- Cancel hint -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/wizard_cancel_hint"
            android:textColor="@color/text_tertiary"
            android:textSize="12sp"
            android:gravity="center" />

    </LinearLayout>

</FrameLayout>
