<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bottom_bar_bg"
    android:padding="12dp">

    <!-- Top content area: left (info) + right (playlist) -->
    <LinearLayout
        android:id="@+id/content_area"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/button_bar">

        <!-- Left panel: cover art + song info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:orientation="vertical"
            android:padding="16dp"
            android:clipChildren="false"
            android:background="@drawable/bg_panel"
            android:clipToOutline="true">

            <!-- Cover art row with vertical volume slider on the left -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:clipChildren="false">

                <!-- Volume slider container — narrow column left of the cover -->
                <FrameLayout
                    android:id="@+id/vol_slider_container"
                    android:layout_width="72dp"
                    android:layout_height="match_parent"
                    android:clipChildren="false">

                    <!-- layout_width set programmatically to container height after layout -->
                    <com.google.android.material.slider.Slider
                        android:id="@+id/vol_slider"
                        android:layout_width="200dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:rotation="270"
                        android:valueFrom="0"
                        android:valueTo="100"
                        android:stepSize="1"
                        app:trackColorActive="@color/colorPrimary"
                        app:trackColorInactive="@color/seekbar_track_bg"
                        app:thumbColor="@color/colorPrimary"
                        app:thumbRadius="10dp"
                        app:labelBehavior="gone" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|center_horizontal"
                        android:paddingBottom="8dp"
                        android:text="VOL"
                        android:maxLines="1"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimary" />

                    <TextView
                        android:id="@+id/vol_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|center_horizontal"
                        android:paddingTop="8dp"
                        android:maxLines="1"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimary" />
                </FrameLayout>

                <ImageView
                    android:id="@+id/cover_art"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:scaleType="fitCenter"
                    android:src="@android:drawable/ic_media_play" />
            </LinearLayout>

            <!-- Song info row: title/artist/album + remaining time spanning all three -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/song_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/no_song"
                        android:textColor="@color/text_primary"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/song_artist"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="30sp"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/song_album"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_tertiary"
                        android:textSize="26sp"
                        android:maxLines="1"
                        android:ellipsize="end" />
                </LinearLayout>

                <TextView
                    android:id="@+id/time_remaining"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:textColor="@color/text_secondary"
                    android:textSize="28sp"
                    android:layout_marginStart="12dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Right panel: playlist content, with settings overlay on top -->
        <FrameLayout
            android:id="@+id/library_panel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_panel"
            android:clipToOutline="true">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/playlist_recycler"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="4dp" />

            <LinearLayout
                android:id="@+id/loading_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <ProgressBar
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    style="?android:attr/progressBarStyle" />

                <TextView
                    android:id="@+id/loading_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium" />

            </LinearLayout>

            <!-- Settings overlay — same bounds as the library panel -->
            <include
                layout="@layout/dialog_settings"
                android:id="@+id/settings_panel"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

        </FrameLayout>

    </LinearLayout>

    <!-- Bottom button bar -->
    <LinearLayout
        android:id="@+id/button_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical"
        android:background="@drawable/bg_panel"
        android:clipToOutline="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <de.codevoid.androsnd.GradientButton
            android:id="@+id/btn_prev"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_bar_height"
            android:layout_weight="1"
            android:layout_margin="@dimen/button_bar_margin"
            android:contentDescription="Previous"
            app:icon="@drawable/ic_previous"
            app:iconGravity="textStart"
            app:iconSize="@dimen/button_bar_icon_size"
            app:iconTint="@color/text_primary"
            style="@style/Widget.Androsnd.Button.Dark" />

        <de.codevoid.androsnd.GradientButton
            android:id="@+id/btn_play"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_bar_height"
            android:layout_weight="1"
            android:layout_margin="@dimen/button_bar_margin"
            android:contentDescription="Play"
            app:icon="@drawable/ic_play"
            app:iconGravity="textStart"
            app:iconSize="@dimen/button_bar_icon_size"
            app:iconTint="@color/text_primary"
            style="@style/Widget.Androsnd.Button.Dark" />

        <de.codevoid.androsnd.GradientButton
            android:id="@+id/btn_next"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_bar_height"
            android:layout_weight="1"
            android:layout_margin="@dimen/button_bar_margin"
            android:contentDescription="Next"
            app:icon="@drawable/ic_next"
            app:iconGravity="textStart"
            app:iconSize="@dimen/button_bar_icon_size"
            app:iconTint="@color/text_primary"
            style="@style/Widget.Androsnd.Button.Dark" />

        <de.codevoid.androsnd.GradientButton
            android:id="@+id/btn_stop"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_bar_height"
            android:layout_weight="1"
            android:layout_margin="@dimen/button_bar_margin"
            android:contentDescription="Stop"
            app:icon="@drawable/ic_stop"
            app:iconGravity="textStart"
            app:iconSize="@dimen/button_bar_icon_size"
            app:iconTint="@color/text_primary"
            style="@style/Widget.Androsnd.Button.Dark" />

        <de.codevoid.androsnd.GradientButton
            android:id="@+id/btn_shuffle"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_bar_height"
            android:layout_weight="1"
            android:layout_margin="@dimen/button_bar_margin"
            android:contentDescription="Shuffle"
            app:icon="@drawable/ic_shuffle"
            app:iconGravity="textStart"
            app:iconSize="@dimen/button_bar_icon_size"
            app:iconTint="@color/text_primary"
            style="@style/Widget.Androsnd.Button.Dark" />

        <de.codevoid.androsnd.GradientButton
            android:id="@+id/btn_settings"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_bar_height"
            android:layout_weight="1"
            android:layout_margin="@dimen/button_bar_margin"
            android:contentDescription="Settings"
            app:icon="@drawable/ic_settings"
            app:iconGravity="textStart"
            app:iconSize="@dimen/button_bar_icon_size"
            app:iconTint="@color/text_primary"
            style="@style/Widget.Androsnd.Button.Outlined" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
