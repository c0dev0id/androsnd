<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:minHeight="@dimen/playlist_folder_min_height"
    android:padding="12dp"
    android:background="?attr/selectableItemBackground"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/folder_cover"
        android:layout_width="@dimen/playlist_folder_cover_size"
        android:layout_height="@dimen/playlist_folder_cover_size"
        android:layout_marginEnd="@dimen/spacing_md"
        android:scaleType="centerCrop"
        android:background="@color/surface_card"
        android:contentDescription="@null" />

    <TextView
        android:id="@+id/folder_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary" />

</LinearLayout>
