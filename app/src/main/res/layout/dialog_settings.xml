<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark"
    android:padding="24dp"
    android:requiresFadingEdge="vertical"
    android:fadingEdgeLength="32dp"
    android:scrollbars="vertical"
    android:fadeScrollbars="false"
    android:scrollbarThumbVertical="@drawable/scrollbar_thumb">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Accent Color -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/accent_color"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:textSize="16sp" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggle_accent_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_accent_orange"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Orange"
                android:textSize="13sp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_accent_blue"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Blue"
                android:textSize="13sp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_accent_green"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Green"
                android:textSize="13sp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- App Volume -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_app_volume"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_volume"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="56dp"
                android:valueFrom="0"
                android:valueTo="100"
                android:stepSize="1"
                app:trackColorActive="@color/colorPrimary"
                app:trackColorInactive="@color/seekbar_track_bg"
                app:thumbColor="@color/colorPrimary"
                app:thumbRadius="16dp"
                app:labelBehavior="gone" />

            <TextView
                android:id="@+id/label_volume"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textColor="@color/colorPrimary"
                android:textStyle="bold"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Overlay Opacity -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_overlay_opacity"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_opacity"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="56dp"
                android:valueFrom="0"
                android:valueTo="100"
                android:stepSize="1"
                app:trackColorActive="@color/colorPrimary"
                app:trackColorInactive="@color/seekbar_track_bg"
                app:thumbColor="@color/colorPrimary"
                app:thumbRadius="16dp"
                app:labelBehavior="gone" />

            <TextView
                android:id="@+id/label_opacity"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textColor="@color/colorPrimary"
                android:textStyle="bold"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Overlay Size -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_overlay_size"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_overlay_size"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="56dp"
                android:valueFrom="0.5"
                android:valueTo="3.0"
                android:stepSize="0.1"
                app:trackColorActive="@color/colorPrimary"
                app:trackColorInactive="@color/seekbar_track_bg"
                app:thumbColor="@color/colorPrimary"
                app:thumbRadius="16dp"
                app:labelBehavior="gone" />

            <TextView
                android:id="@+id/label_overlay_size"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textColor="@color/colorPrimary"
                android:textStyle="bold"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Double-Tap Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp">

            <TextView
                android:id="@+id/label_double_tap_section"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/settings_double_tap_enabled"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textSize="16sp" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_double_tap"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <TextView
            android:id="@+id/label_double_tap_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_double_tap_description"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:id="@+id/double_tap_slider_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/label_double_tap_heading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_double_tap"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginTop="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_double_tap"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="56dp"
                    android:valueFrom="300"
                    android:valueTo="2000"
                    android:stepSize="50"
                    app:trackColorActive="@color/colorPrimary"
                    app:trackColorInactive="@color/seekbar_track_bg"
                    app:thumbColor="@color/colorPrimary"
                    app:thumbRadius="16dp"
                    app:labelBehavior="gone" />

                <TextView
                    android:id="@+id/label_double_tap"
                    android:layout_width="64dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/colorPrimary"
                    android:textStyle="bold"
                    android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Select Folder -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_folder"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="24dp"
            android:text="@string/select_folder"
            android:textSize="14sp"
            android:textStyle="bold"
            style="@style/Widget.Androsnd.Button.Outlined" />

        <!-- Remote Key Mapping (opens wizard overlay) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_remote_keys"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="@string/wizard_settings_button"
            android:textSize="14sp"
            android:textStyle="bold"
            style="@style/Widget.Androsnd.Button.Outlined" />

    </LinearLayout>
</ScrollView>
